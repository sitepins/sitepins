# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------
PORT=4000
NODE_ENV="development"
BASE_URL="http://localhost:4000"

# MongoDB connection string (local or Atlas)
MONGO_URI=""

# Comma-separated list of allowed browser origins in production.
CORS_ORIGINS="https://cms.example.com"

# Number of proxies in front of the API (Vercel/DO/nginx). Unset defaults to
# 1 in production, off in development. Set "false" if exposed directly.
# TRUST_PROXY=1

# Max request body size (anti-DoS).
# JSON_BODY_LIMIT=5mb

# ---------------------------------------------------------------------------
# Auth & security
# ---------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""

# bcrypt cost factor (rounds). Defaults to 10 if unset.
SALT=10

# JWT (admin/integration tokens)
JWT_SECRET=""
JWT_TOKEN_EXPIRE="7d"

# Session cookie domain. LEAVE UNSET for a single-host deploy. Only set it (to
# a leading-dot domain, e.g. ".example.com") when the web app and API run on
# different subdomains of the same site and must share the session cookie.
# COOKIE_DOMAIN=".example.com"

# Rate limit (better-auth): max requests per window (seconds).
RATELIMIT_WINDOW=10
RATELIMIT_MAX=100

# Internal server-to-server secret (used by the web app's API routes).
INTERNAL_API_SECRET=""

# AES-256-GCM key for encrypting sandbox tokens at rest.
# Generate with: openssl rand -hex 32
SANDBOX_ENCRYPTION_KEY=""

# ---------------------------------------------------------------------------
# OAuth providers
# ---------------------------------------------------------------------------
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---------------------------------------------------------------------------
# Media storage (S3-compatible: AWS S3, Cloudflare R2, MinIO, Backblaze B2,
# DigitalOcean Spaces). See README "Setting up media storage".
# ---------------------------------------------------------------------------
S3_ENDPOINT=""            # AWS https://s3.<region>.amazonaws.com | R2 https://<acct>.r2.cloudflarestorage.com | DO https://<region>.digitaloceanspaces.com
S3_REGION=""              # e.g. us-east-1  (use "auto" for R2)
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET_NAME=""
S3_FORCE_PATH_STYLE=false # set true for MinIO / path-style gateways

# ---------------------------------------------------------------------------
# Transactional email (optional)
# Provider: "brevo" | "smtp" | "console". Unset = auto-detect: Brevo if
# BREVO_API_KEY is set, else SMTP if SMTP_HOST is set, else "console" (logs
# the OTP / reset link to stdout so signup works with no mail setup).
# Set REQUIRE_EMAIL_VERIFICATION=false to skip OTP entirely.
# ---------------------------------------------------------------------------
# MAIL_PROVIDER=""
REQUIRE_EMAIL_VERIFICATION=true
MAIL_FROM_NAME="Sitepins"
MAIL_FROM_EMAIL="noreply@example.com"

# SMTP (when MAIL_PROVIDER=smtp or auto-detected)
# SMTP_HOST=""
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=""
# SMTP_PASS=""

# Brevo (when MAIL_PROVIDER=brevo or auto-detected)
# BREVO_API_KEY=""
# Override the numeric Brevo template ids to match your own account:
# BREVO_TEMPLATE_WELCOME=1
# BREVO_TEMPLATE_OTP=59
# BREVO_TEMPLATE_PASSWORD_RESET=60
# BREVO_TEMPLATE_DELETE_ACCOUNT=32
# BREVO_TEMPLATE_ORG_MEMBER_ADDED=61
# BREVO_TEMPLATE_ORG_MEMBER_UPDATED=62
# BREVO_TEMPLATE_ORG_MEMBER_REMOVED=63

# Optional anti-abuse email validation at signup (https://reoon.com).
# Empty = skipped. Fails open if the service is down.
REOON_API_KEY=""
