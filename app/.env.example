# ---------------------------------------------------------------------------
# Backend
# ---------------------------------------------------------------------------
# Backend API URL (the api/ server)
NEXT_PUBLIC_BACKEND_URL=""

# internal secret for project preview (must match api/.env INTERNAL_API_SECRET)
INTERNAL_API_SECRET=""

# WebSocket URL for collaborative editing
NEXT_PUBLIC_HP_WS_URL="ws://localhost:4000/api/v1/editor/collab"
# for production: wss://api.example.com/api/v1/editor/collab

# Where "/dashboard" redirects to. Defaults to /dashboard/account.
# NEXT_PUBLIC_DASHBOARD_HOME="/dashboard/account"

# ---------------------------------------------------------------------------
# Branding — override so a fork doesn't ship the upstream Sitepins identity
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_BRAND_NAME="Sitepins"
# NEXT_PUBLIC_BRAND_URL="https://sitepins.com"
# NEXT_PUBLIC_SUPPORT_URL="https://sitepins.com/contact"
# NEXT_PUBLIC_UPDATES_URL="https://updates.sitepins.com"
# NEXT_PUBLIC_COMMUNITY_URL="https://discord.gg/KrpvHfqcNA"
# Domain used for the CMS git commit author email (defaults to BRAND_URL host)
# NEXT_PUBLIC_GIT_COMMIT_EMAIL_DOMAIN="sitepins.com"

# ---------------------------------------------------------------------------
# Media bucket (must match api/.env S3 config)
# ---------------------------------------------------------------------------
# Public base URL of your S3-compatible bucket, e.g.
#   https://<bucket>.<region>.digitaloceanspaces.com  (DO Spaces)
#   https://<bucket>.s3.<region>.amazonaws.com          (AWS)
NEXT_PUBLIC_BUCKET_URL=""

# ---------------------------------------------------------------------------
# GitHub app (git provider)
# ---------------------------------------------------------------------------
GITHUB_APP_ID=""
GITHUB_APP_CLIENT_ID=""
GITHUB_APP_CLIENT_SECRET=""
GITHUB_APP_PRIVATE_KEY=""
NEXT_PUBLIC_GITHUB_APP_NAME=""

# ---------------------------------------------------------------------------
# GitLab app (git provider)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_GITLAB_APP_NAME=""
NEXT_PUBLIC_GITLAB_CLIENT_ID=""
GITLAB_CLIENT_SECRET=""

# ---------------------------------------------------------------------------
# AI assist (optional) — key for the editor copilot route. Users can also
# supply their own key in the UI.
# ---------------------------------------------------------------------------
AI_GATEWAY_API_KEY=""

# ---------------------------------------------------------------------------
# Demo account (optional)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_IS_DEMO=false
NEXT_PUBLIC_DEMO_EMAIL=""
NEXT_PUBLIC_DEMO_PASSWORD=""
